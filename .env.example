OPENAI_EXTRACTION_MODEL=gpt-5-nano
ARTICLE_CANDIDATE_TOP_K=3
RELATION_CONFIDENCE_THRESHOLD=0.85
LLM_MAX_WORKERS=10
OPENAI_API_KEY=
